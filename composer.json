{
	"description": "Find the instances of an executable in the system path. Like the `which` Linux command.",
	"homepage": "https://github.com/CedX/Which.php",
	"license": "MIT",
	"name": "cedx/which",
	"type": "library",
	"version": "12.0.0",
	"authors": [
		{"email": "cedx@outlook.com", "homepage": "https://cedric-belin.fr", "name": "Cédric Belin"}
	],
	"autoload": {
		"files": ["Sources/Main.php"],
		"psr-4": {"Belin\\Which\\": "Sources/"}
	},
	"autoload-dev": {
		"psr-4": {"Belin\\Which\\": "Tests/"}
	},
	"config": {
		"platform-check": false
	},
	"keywords": [
		"find",
		"path",
		"system",
		"utility",
		"which"
	],
	"require": {
		"php": ">=8.5.0",
		"ext-mbstring": "*",
		"ext-spl": "*",
		"symfony/filesystem": "^8.0.11"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1.55",
		"phpunit/phpunit": "^13.1.10"
	},
	"support": {
		"docs": "https://github.com/CedX/Which.php/tree/main/Documentation",
		"issues": "https://github.com/CedX/Which.php/issues"
	}
}
